generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection string — used by the serverless functions at runtime.
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection — used for migrations only. On providers
  // without connection pooling (e.g. a plain Railway/Render Postgres) this
  // can be the same value as DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Every business table carries storeId even though Phase 1 only ever runs a
// single Store row. That keeps a future multi-store rollout a config change
// instead of a data migration.
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  MANAGER
  CASHIER
  STOREKEEPER
  ACCOUNTANT
}

enum CustomerType {
  RETAIL
  WHOLESALE
  VIP
}

enum SupplierTransactionType {
  PURCHASE
  PAYMENT
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PromotionType {
  PERCENTAGE_DISCOUNT
  FIXED_DISCOUNT
  BOGO
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PaymentMethod {
  CASH
  // Cashier-asserted M-Pesa payment — the customer already paid (e.g. sent
  // money to a till/paybill outside this system) and the cashier is just
  // recording it, same trust level as CARD/BANK. No STK push involved.
  MPESA_MANUAL
  // STK Push-verified M-Pesa payment — requires a confirmed MpesaTransaction
  // (see sales.ts) before the sale is allowed to complete.
  MPESA
  CARD
  BANK
  SPLIT
  CREDIT
}

enum SaleStatus {
  HELD
  COMPLETED
  VOIDED
  REFUNDED
}

enum RegisterSessionStatus {
  OPEN
  CLOSED
}

enum StockAdjustmentReason {
  RECEIVED_STOCK
  DAMAGE
  THEFT_LOSS
  RECOUNT
  MANUAL_CORRECTION
}

enum MpesaTransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  currency  String   @default("KES")
  taxRate   Decimal  @default(16) @db.Decimal(5, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  categories           Category[]
  products             Product[]
  sales                Sale[]
  registerSessions     CashRegisterSession[]
  stockAdjustments     StockAdjustment[]
  customers            Customer[]
  suppliers            Supplier[]
  supplierTransactions SupplierTransaction[]
  creditPayments       CreditPayment[]
  expenseCategories    ExpenseCategory[]
  expenses             Expense[]
  incomes              Income[]
  promotions           Promotion[]
  coupons              Coupon[]
  mpesaTransactions    MpesaTransaction[]
}

model User {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CASHIER)
  // Per-employee permission overrides on top of the role's defaults.
  // Null/absent keys fall back to ROLE_DEFAULT_PERMISSIONS for that role.
  permissions  Json?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sales                Sale[]
  registerSessions     CashRegisterSession[]
  stockAdjustments     StockAdjustment[]
  supplierTransactions SupplierTransaction[]
  creditPayments       CreditPayment[]
  requestedExpenses    Expense[]             @relation("ExpenseRequestedBy")
  approvedExpenses     Expense[]             @relation("ExpenseApprovedBy")
  mpesaTransactions    MpesaTransaction[]

  @@index([storeId])
}

model Category {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@unique([storeId, name])
  @@index([storeId])
}

model Product {
  id                String    @id @default(cuid())
  storeId           String
  store             Store     @relation(fields: [storeId], references: [id])
  categoryId        String?
  category          Category? @relation(fields: [categoryId], references: [id])
  name              String
  sku               String
  barcode           String?
  price             Decimal   @db.Decimal(12, 2)
  wholesalePrice    Decimal?  @db.Decimal(12, 2)
  vipPrice          Decimal?  @db.Decimal(12, 2)
  cost              Decimal?  @db.Decimal(12, 2)
  stockQty          Int       @default(0)
  lowStockThreshold Int       @default(5)
  imageUrl          String?
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  // Idempotency key for a product created offline and retried on sync — see
  // clientId on Sale for the same pattern. Null for products created online,
  // which have no retry-a-lost-response risk worth guarding against.
  clientId          String?   @unique

  saleItems        SaleItem[]
  stockAdjustments StockAdjustment[]

  @@unique([storeId, sku])
  @@index([storeId])
  @@index([storeId, barcode])
}

model Sale {
  id                String               @id @default(cuid())
  storeId           String
  store             Store                @relation(fields: [storeId], references: [id])
  cashierId         String
  cashier           User                 @relation(fields: [cashierId], references: [id])
  registerSessionId String?
  registerSession   CashRegisterSession? @relation(fields: [registerSessionId], references: [id])
  customerId        String?
  customer          Customer?            @relation(fields: [customerId], references: [id])
  couponId          String?
  coupon            Coupon?              @relation(fields: [couponId], references: [id])

  // Client-generated id so an offline sale keeps a stable identity through sync.
  clientId String @unique

  status             SaleStatus    @default(COMPLETED)
  subtotal           Decimal       @db.Decimal(12, 2)
  discountTotal      Decimal       @default(0) @db.Decimal(12, 2)
  taxTotal           Decimal       @db.Decimal(12, 2)
  total              Decimal       @db.Decimal(12, 2)
  amountTendered     Decimal?      @db.Decimal(12, 2)
  changeDue          Decimal?      @db.Decimal(12, 2)
  paymentMethod      PaymentMethod @default(CASH)
  creditDueDate      DateTime?
  // Set from the linked MpesaTransaction once an STK push succeeds, so
  // receipts/reports can show it without an extra join.
  mpesaReceiptNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  syncedAt  DateTime @default(now())

  items            SaleItem[]
  splitPayments    SalePayment[]
  mpesaTransaction MpesaTransaction?

  @@index([storeId])
  @@index([storeId, createdAt])
}

// Only populated when paymentMethod is SPLIT — the breakdown across methods.
model SalePayment {
  id     String        @id @default(cuid())
  saleId String
  sale   Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  method PaymentMethod
  amount Decimal       @db.Decimal(12, 2)

  @@index([saleId])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  unitPrice Decimal @db.Decimal(12, 2)
  quantity  Int
  lineTotal Decimal @db.Decimal(12, 2)

  @@index([saleId])
}

// One row per Safaricom STK Push request. Created PENDING when the push is
// sent, then updated by the (unauthenticated, Safaricom-facing) callback
// route once the customer accepts/declines/times out on their phone.
// `saleId` is only set after a matching Sale is created from a SUCCESS
// transaction — see POST /api/sales's MPESA handling. `checkoutRequestId`
// is the token both the status-poll and callback routes look this row up by.
model MpesaTransaction {
  id                 String                 @id @default(cuid())
  storeId            String
  store              Store                  @relation(fields: [storeId], references: [id])
  cashierId          String
  cashier            User                   @relation(fields: [cashierId], references: [id])
  phone              String
  amount             Decimal                @db.Decimal(12, 2)
  merchantRequestId  String
  checkoutRequestId  String                 @unique
  status             MpesaTransactionStatus @default(PENDING)
  resultCode         Int?
  resultDesc         String?
  mpesaReceiptNumber String?
  saleId             String?                @unique
  sale               Sale?                  @relation(fields: [saleId], references: [id])
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([storeId])
}

model CashRegisterSession {
  id             String                @id @default(cuid())
  storeId        String
  store          Store                 @relation(fields: [storeId], references: [id])
  cashierId      String
  cashier        User                  @relation(fields: [cashierId], references: [id])
  status         RegisterSessionStatus @default(OPEN)
  openingFloat   Decimal               @db.Decimal(12, 2)
  closingCounted Decimal?              @db.Decimal(12, 2)
  expectedCash   Decimal?              @db.Decimal(12, 2)
  variance       Decimal?              @db.Decimal(12, 2)
  openedAt       DateTime              @default(now())
  closedAt       DateTime?
  notes          String?

  sales Sale[]

  @@index([storeId])
}

model StockAdjustment {
  id            String                @id @default(cuid())
  storeId       String
  store         Store                 @relation(fields: [storeId], references: [id])
  productId     String
  product       Product               @relation(fields: [productId], references: [id])
  userId        String
  user          User                  @relation(fields: [userId], references: [id])
  reason        StockAdjustmentReason
  quantityDelta Int
  notes         String?
  createdAt     DateTime              @default(now())
  // Idempotency key for an adjustment queued offline and retried on sync —
  // without this, retrying a dropped-response POST would double-apply the
  // delta (unlike a full-overwrite PUT, incrementing stock isn't naturally
  // safe to repeat).
  clientId      String?               @unique

  @@index([storeId])
  @@index([productId])
}

model Customer {
  id            String       @id @default(cuid())
  storeId       String
  store         Store        @relation(fields: [storeId], references: [id])
  name          String
  phone         String?
  email         String?
  type          CustomerType @default(RETAIL)
  creditLimit   Decimal      @default(0) @db.Decimal(12, 2)
  creditBalance Decimal      @default(0) @db.Decimal(12, 2)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  sales          Sale[]
  creditPayments CreditPayment[]

  @@index([storeId])
}

model CreditPayment {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  amount       Decimal  @db.Decimal(12, 2)
  notes        String?
  recordedById String
  recordedBy   User     @relation(fields: [recordedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([storeId])
  @@index([customerId])
}

model Supplier {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  name      String
  phone     String?
  email     String?
  address   String?
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions SupplierTransaction[]

  @@index([storeId])
}

model SupplierTransaction {
  id           String                  @id @default(cuid())
  storeId      String
  store        Store                   @relation(fields: [storeId], references: [id])
  supplierId   String
  supplier     Supplier                @relation(fields: [supplierId], references: [id])
  type         SupplierTransactionType
  amount       Decimal                 @db.Decimal(12, 2)
  description  String?
  recordedById String
  recordedBy   User                    @relation(fields: [recordedById], references: [id])
  createdAt    DateTime                @default(now())

  @@index([storeId])
  @@index([supplierId])
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  name      String
  createdAt DateTime @default(now())

  expenses Expense[]

  @@unique([storeId, name])
  @@index([storeId])
}

model Expense {
  id            String          @id @default(cuid())
  storeId       String
  store         Store           @relation(fields: [storeId], references: [id])
  categoryId    String
  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
  amount        Decimal         @db.Decimal(12, 2)
  description   String?
  date          DateTime        @default(now())
  status        ExpenseStatus   @default(PENDING)
  requestedById String
  requestedBy   User            @relation("ExpenseRequestedBy", fields: [requestedById], references: [id])
  approvedById  String?
  approvedBy    User?           @relation("ExpenseApprovedBy", fields: [approvedById], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([storeId])
}

model Income {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  source      String
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([storeId])
}

model Promotion {
  id              String        @id @default(cuid())
  storeId         String
  store           Store         @relation(fields: [storeId], references: [id])
  name            String
  type            PromotionType
  discountPercent Decimal?      @db.Decimal(5, 2)
  discountAmount  Decimal?      @db.Decimal(12, 2)
  productId       String?
  startDate       DateTime
  endDate         DateTime
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([storeId])
  @@index([storeId, active, startDate, endDate])
}

model Coupon {
  id            String       @id @default(cuid())
  storeId       String
  store         Store        @relation(fields: [storeId], references: [id])
  code          String
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(12, 2)
  expiresAt     DateTime?
  usageLimit    Int?
  timesUsed     Int          @default(0)
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())

  sales Sale[]

  @@unique([storeId, code])
  @@index([storeId])
}
