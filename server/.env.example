DATABASE_URL="postgresql://postgres:postgres@localhost:5432/anakel_pos?schema=public"
# On Vercel Postgres/Neon, DATABASE_URL is the pooled connection string and
# DIRECT_URL is the non-pooled one (used only for migrations). On a plain
# Postgres with no pooler, both can be the same value.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/anakel_pos?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=4000
# Comma-separated list of allowed web origins
CORS_ORIGIN="http://localhost:5173"

# M-Pesa (Safaricom Daraja) — optional. Without these, the app runs fine and
# POST /api/mpesa/stk-push just returns 503. Get a free sandbox Consumer
# Key/Secret at developer.safaricom.co.ke. See docs/DEPLOYMENT.md for setup.
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# Safaricom's published sandbox test values — override with your own
# shortcode/passkey when moving to production.
# MPESA_SHORTCODE=174379
# MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# MPESA_ENV=sandbox
# Must be a public HTTPS URL Safaricom's servers can reach — not localhost.
# MPESA_CALLBACK_URL=
